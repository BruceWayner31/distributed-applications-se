@model IEnumerable<WebApplication6.Models.Venues>
@{
    ViewData["Title"] = "Venues";
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Venues</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Venue</a>
</div>

@* ── Filter form ── *@
<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input type="text" name="search" value="@ViewBag.Search"
               placeholder="Search by title..." class="form-control" />
    </div>

    <div class="col-md-2">
        <select name="sortBy" class="form-select">
  
            <option value="Name" selected="@(ViewBag.SortBy == "Name")">Sort: Name</option>
            <option value="City" selected="@(ViewBag.SortBy == "City")">Sort: City</option>
            <option value="Capacity" selected="@(ViewBag.SortBy == "Capacity")">Sort: Capacity</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Search</button>
    </div>
    <div class="col-md-1">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
    </div>
</form>
<table class="table table-striped table-hover">
<thead class="table-dark">
    <tr>
       
        <th>Name</th>
        <th>Address</th>
        <th>City</th>
        <th>Description</th>
        <th>ContactEmail</th>
        <th>Capacity</th>
        <th>CreatedAt</th>
    </tr>
</thead>
<tbody>
    @foreach (var venues in Model)
    {
        <tr>
            <td>@venues.Name</td>
            <td>@venues.Address</td>
            <td>@venues.City</td>
            <td>@venues.Description</td>
            <td>@venues.ContactEmail</td>           
            <td>@venues.Capacity</td>
            <td>@venues.CreatedAt.ToString("dd MMM yyyy")</td>
          
          
           
        <td>
            <a asp-action="Details" asp-route-id="@venues.Id" class="btn btn-sm btn-info">Details</a>
            <a asp-action="Edit" asp-route-id="@venues.Id" class="btn btn-sm btn-warning">Edit</a>
            <a asp-action="Delete" asp-route-id="@venues.Id" class="btn btn-sm btn-danger">Delete</a>
        </td>
    </tr>
        }
</tbody>
</table>
<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@i"
                   asp-route-search="@ViewBag.Search"
                   asp-route-status="@ViewBag.City"
                   asp-route-sortBy="@ViewBag.SortBy">@i</a>
            </li>
        }
    </ul>
</nav>
@{
}
