@model WebApplication6.Models.Venues
@{
    ViewData["Title"] = "Edit Venue";
}

<h2>Edit Venue</h2>
<hr />

@* exactly the same form as Create but with hidden Id field *@
<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @* IMPORTANT: hidden field so the Id is posted back *@
    <input asp-for="Id" type="hidden" />
    <input asp-for="CreatedAt" type="hidden" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>

    <div class="row">
        <div class="col mb-3">
            <label asp-for="Address" class="form-label"></label>
            <input asp-for="Address"  class="form-control" />
        </div>
        <div class="col mb-3">
            <label asp-for="City" class="form-label"></label>
            <input asp-for="City"  class="form-control" />
        </div>
    </div>

    <div class="row">
        <div class="col mb-3">
            <label asp-for="Capacity" class="form-label"></label>
            <input asp-for="Capacity" type="number" class="form-control" />
        </div>
        <div class="col mb-3">
            <label asp-for="ContactEmail" class="form-label"></label>
            <input asp-for="ContactEmail"  class="form-control" />
        </div>
      
    </div>

    <button type="submit" class="btn btn-warning">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}