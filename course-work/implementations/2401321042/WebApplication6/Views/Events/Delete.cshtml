@model WebApplication6.Models.Events
@{ ViewData["Title"] = "Delete Event"; }

<h2>Delete Event</h2>
<hr />

<div class="alert alert-danger">
    Are you sure you want to delete <strong>@Model.Title</strong>?
    This action cannot be undone.
</div>

<dl class="row">
    <dt class="col-sm-3">Title</dt>
    <dd class="col-sm-9">@Model.Title</dd>

    <dt class="col-sm-3">Venue</dt>
    <dd class="col-sm-9">@Model.Venues?.Name</dd>

    <dt class="col-sm-3">Start Date</dt>
    <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>