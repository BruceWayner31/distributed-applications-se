@model IEnumerable<WebApplication6.Models.Events>
@{
    ViewData["Title"] = "Events";
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}
@if(User.IsInRole("Admin")||User.IsInRole("Organizer"))
{
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Events</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Event</a>
</div>
}


@* ── Filter form ── *@
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search"
               placeholder="Search by title..." class="form-control" />
    </div>
    <div class="col-md-3">
        <select name="status" class="form-select">
            <option value="">All statuses</option>
            <option value="Draft" selected="@(ViewBag.Status == "Draft")">Draft</option>
            <option value="Published" selected="@(ViewBag.Status == "Published")">Published</option>
            <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Cancelled</option>
            <option value="Completed" selected="@(ViewBag.Status == "Completed")">Completed</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="sortBy" class="form-select">
            <option value="StartDate" selected="@(ViewBag.SortBy == "StartDate")">Sort: Date</option>
            <option value="Title" selected="@(ViewBag.SortBy == "Title")">Sort: Title</option>
            <option value="Price" selected="@(ViewBag.SortBy == "Price")">Sort: Price</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Search</button>
    </div>
    <div class="col-md-1">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
    </div>
</form>

@* ── Table ── *@
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Venue</th>
            <th>Start Date</th>
            <th>Price</th>
            <th>Capacity</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var evt in Model)
        {
            <tr>
                <td>@evt.Title</td>
                <td>@evt.Venues?.Name</td>
                <td>@evt.StartDate.ToString("dd MMM yyyy")</td>
                <td>@(evt.TicketPrice == 0 ? "Free" : $"${evt.TicketPrice:F2}")</td>
                <td>@evt.MaxCapacity</td>
                <td>
                    <span class="badge
                        @(evt.Status == "Published" ? "bg-success" :
                                                evt.Status == "Cancelled" ? "bg-danger" :
                                                evt.Status == "Completed" ? "bg-secondary" : "bg-warning text-dark")">
                    @evt.Status
                </span>
            </td>
                @if (User.IsInRole("Admin") || User.IsInRole("Organizer"))
                {
                    <td>
                        <a asp-action="Details" asp-route-id="@evt.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@evt.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@evt.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
            }
        </tr>
                }
    </tbody>
</table>

@* ── Pagination ── *@
<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@i"
                   asp-route-search="@ViewBag.Search"
                   asp-route-status="@ViewBag.Status"
                   asp-route-sortBy="@ViewBag.SortBy">@i</a>
            </li>
        }
    </ul>
</nav>