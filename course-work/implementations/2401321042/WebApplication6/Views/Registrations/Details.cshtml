@model WebApplication6.Models.Registrations
@{
    ViewData["Title"] = "Registration Details";
}

<h2>Registration Details</h2>
<hr />

<dl class="row">
    <dt class="col-sm-3">User</dt>
    <dd class="col-sm-9">@Model.Users?.Username (@Model.Users?.Email)</dd>

    <dt class="col-sm-3">Event</dt>
    <dd class="col-sm-9">@Model.Events?.Title</dd>

    <dt class="col-sm-3">Ticket Count</dt>
    <dd class="col-sm-9">@Model.TicketCount</dd>

    <dt class="col-sm-3">Total Price</dt>
    <dd class="col-sm-9">$@Model.TotalPrice.ToString("F2")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        <span class="badge
            @(Model.Status == "Confirmed" ? "bg-success" :
                            Model.Status == "Cancelled" ? "bg-danger" : "bg-warning text-dark")">
            @Model.Status
        </span>
    </dd>

    <dt class="col-sm-3">Notes</dt>
    <dd class="col-sm-9">@Model.Notes</dd>

    <dt class="col-sm-3">Registered At</dt>
    <dd class="col-sm-9">@Model.RegisteredAt.ToString("dd MMM yyyy HH:mm")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to list</a>
