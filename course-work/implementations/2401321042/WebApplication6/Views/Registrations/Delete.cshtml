@model WebApplication6.Models.Registrations
@{
    ViewData["Title"] = "Delete Registration";
}

<h2>Delete Registration</h2>
<hr />

<div class="alert alert-danger">
    Are you sure you want to delete this registration? This action cannot be undone.
</div>

<dl class="row">
    <dt class="col-sm-3">User</dt>
    <dd class="col-sm-9">@Model.Users?.Username</dd>

    <dt class="col-sm-3">Event</dt>
    <dd class="col-sm-9">@Model.Events?.Title</dd>

    <dt class="col-sm-3">Tickets</dt>
    <dd class="col-sm-9">@Model.TicketCount</dd>

    <dt class="col-sm-3">Total Price</dt>
    <dd class="col-sm-9">$@Model.TotalPrice.ToString("F2")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete" method="post">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
