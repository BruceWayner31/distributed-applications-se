@model WebApplication6.Models.Users
@{
    ViewData["Title"] = "User Details";
}

<h2>User Details</h2>
<hr />

<dl class="row">
    <dt class="col-sm-3">Username</dt>
    <dd class="col-sm-9">@Model.Username</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">First Name</dt>
    <dd class="col-sm-9">@Model.Fname</dd>

    <dt class="col-sm-3">Last Name</dt>
    <dd class="col-sm-9">@Model.Lname</dd>

    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@Model.Phone</dd>

    <dt class="col-sm-3">Role</dt>
    <dd class="col-sm-9">
        <span class="badge
            @(Model.Role == "Admin" ? "bg-danger" :
                            Model.Role == "Organizer" ? "bg-primary" : "bg-secondary")">
            @Model.Role
        </span>
    </dd>

    <dt class="col-sm-3">Created At</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back to list</a>
