@model IEnumerable<WebApplication6.Models.Users>
@{
    ViewData["Title"] = "Users";
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Users</h2>
    <a asp-action="Create" class="btn btn-primary">+ New User</a>
</div>



<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search"
               placeholder="Search by username or email..." class="form-control" />
    </div>
    <div class="col-md-3">
        <select name="role" class="form-select">
            <option value="">All roles</option>
            <option value="Admin" selected="@(ViewBag.Role == "Admin")">Admin</option>
            <option value="Organizer" selected="@(ViewBag.Role == "Organizer")">Organizer</option>
            <option value="Attendee" selected="@(ViewBag.Role == "Attendee")">Attendee</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="sortBy" class="form-select">
            <option value="Username" selected="@(ViewBag.SortBy == "Username")">Sort: Username</option>
            <option value="Email" selected="@(ViewBag.SortBy == "Email")">Sort: Email</option>
            <option value="CreatedAt" selected="@(ViewBag.SortBy == "CreatedAt")">Sort: Date</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Search</button>
    </div>
    <div class="col-md-1">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Role</th>
            <th>Created</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Username</td>
                <td>@user.Email</td>
                <td>@user.Fname</td>
                <td>@user.Lname</td>
                <td>
                    <span class="badge
                        @(user.Role == "Admin" ? "bg-danger" :
                                                user.Role == "Organizer" ? "bg-primary" : "bg-secondary")">
                    @user.Role
                </span>
            </td>
            <td>@user.CreatedAt.ToString("dd MMM yyyy")</td>
            <td>
                <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
                }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@i"
                   asp-route-search="@ViewBag.Search"
                   asp-route-role="@ViewBag.Role"
                   asp-route-sortBy="@ViewBag.SortBy">@i</a>
            </li>
        }
    </ul>
</nav>
