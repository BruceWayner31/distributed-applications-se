@model IEnumerable<WebApplication6.Models.EventCategories>
@{
    ViewData["Title"] = "Event Categories";
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Event Categories</h2>
    <a asp-action="Create" class="btn btn-primary">+ Assign Category</a>
</div>


<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="eventId" value="@ViewBag.EventId"
               placeholder="Filter by Event ID..." class="form-control" />
    </div>
    <div class="col-md-4">
        <input type="text" name="categoryId" value="@ViewBag.CategoryId"
               placeholder="Filter by Category ID..." class="form-control" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Search</button>
    </div>
    <div class="col-md-2">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Event</th>
            <th>Category</th>
            <th>Assigned At</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ec in Model)
        {
            <tr>
                <td>@ec.Events?.Title</td>
                <td>
                    <span class="badge" style="background-color:@ec.Categories?.ColorHex">
                        @ec.Categories?.Name
                    </span>
                </td>
                <td>@ec.AssignedAt.ToString("dd MMM yyyy HH:mm")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@ec.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@ec.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@ec.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@i"
                   asp-route-sortBy="@ViewBag.SortBy">@i</a>
            </li>
        }
    </ul>
</nav>
