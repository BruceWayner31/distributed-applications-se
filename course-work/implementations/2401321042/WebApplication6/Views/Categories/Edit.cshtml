@model WebApplication6.Models.Categories
@{
    ViewData["Title"] = "Edit Category";
}

<h2>Edit Category</h2>
<hr />

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="Id" type="hidden" />
    <input asp-for="Created" type="hidden" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="ColorHex" class="form-label"></label>
        <input asp-for="ColorHex" type="color" class="form-control form-control-color" />
        <span asp-validation-for="ColorHex" class="text-danger"></span>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="isActived" class="form-check-input" />
        <label asp-for="isActived" class="form-check-label">Active</label>
    </div>

    <button type="submit" class="btn btn-warning">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
