@model IEnumerable<WebApplication6.Models.Categories>
@{
    ViewData["Title"] = "Categories";
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Categories</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Category</a>
</div>



<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search"
               placeholder="Search by name..." class="form-control" />
    </div>
    <div class="col-md-3">
        <select name="isActive" class="form-select">
            <option value="">All</option>
            <option value="true" selected="@(ViewBag.IsActive == "true")">Active</option>
            <option value="false" selected="@(ViewBag.IsActive == "false")">Inactive</option>
        </select>
    </div>
    <div class="col-md-2">
        <select name="sortBy" class="form-select">
            <option value="Name" selected="@(ViewBag.SortBy == "Name")">Sort: Name</option>
            <option value="CreatedAt" selected="@(ViewBag.SortBy == "CreatedAt")">Sort: Date</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-secondary w-100">Search</button>
    </div>
    <div class="col-md-1">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Color</th>
            <th>Name</th>
            <th>Description</th>
            <th>Active</th>
            <th>Created</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cat in Model)
        {
            <tr>
                <td>
                    <span style="display:inline-block;width:24px;height:24px;border-radius:4px;background:@cat.ColorHex;border:1px solid #ccc;"></span>
                </td>
                <td>@cat.Name</td>
                <td>@cat.Description</td>
                <td>
                    <span class="badge @(cat.isActived ? "bg-success" : "bg-secondary")">
                        @(cat.isActived ? "Active" : "Inactive")
                    </span>
                </td>
                <td>@cat.Created.ToString("dd MMM yyyy")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@cat.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@cat.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@i"
                   asp-route-search="@ViewBag.Search"
                   asp-route-isActive="@ViewBag.IsActive"
                   asp-route-sortBy="@ViewBag.SortBy">@i</a>
            </li>
        }
    </ul>
</nav>
