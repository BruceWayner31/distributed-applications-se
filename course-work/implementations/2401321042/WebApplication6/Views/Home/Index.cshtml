@model IEnumerable<WebApplication6.Models.Events>
@{
    ViewData["Title"] = "Eventify — Discover Events";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ── HERO ── */
    .hero {
        position: relative;
        padding: 5rem 0 4rem;
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(232,255,71,0.08) 0%, transparent 60%), radial-gradient(ellipse 40% 40% at 80% 50%, rgba(255,107,53,0.06) 0%, transparent 50%);
        pointer-events: none;
    }

    .hero-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        background: rgba(232,255,71,0.08);
        border: 1px solid rgba(232,255,71,0.15);
        padding: 6px 14px;
        border-radius: 20px;
        margin-bottom: 1.5rem;
        animation: fadeUp 0.6s ease both;
    }

    .hero-label-dot {
        width: 6px;
        height: 6px;
        background: var(--accent);
        border-radius: 50%;
        animation: pulse 2s ease-in-out infinite;
    }

    .hero-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.05;
        color: var(--text);
        margin-bottom: 1.25rem;
        animation: fadeUp 0.6s ease 0.1s both;
    }

        .hero-title span {
            color: transparent;
            -webkit-text-stroke: 1px rgba(232,255,71,0.5);
        }

    .hero-sub {
        font-size: 1.05rem;
        color: var(--muted);
        max-width: 480px;
        margin-bottom: 2.5rem;
        line-height: 1.7;
        animation: fadeUp 0.6s ease 0.2s both;
    }

    .hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        animation: fadeUp 0.6s ease 0.3s both;
    }

    .hero-stat {
        display: flex;
        gap: 2rem;
        margin-top: 3rem;
        animation: fadeUp 0.6s ease 0.4s both;
    }

    .stat-item {
    }

    .stat-num {
        font-family: 'Syne', sans-serif;
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.02em;
    }

    .stat-label {
        font-size: 0.8rem;
        color: var(--muted);
        margin-top: 2px;
    }

    /* ── SECTION ── */
    .section-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 2rem;
        gap: 1rem;
    }

    .section-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--text);
        margin: 0;
    }

    .section-sub {
        font-size: 0.85rem;
        color: var(--muted);
        margin: 4px 0 0;
    }

    /* ── EVENT CARDS ── */
    .events-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.25rem;
    }

    .ev-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        animation: fadeUp 0.5s ease both;
        cursor: pointer;
        text-decoration: none;
        display: block;
        color: inherit;
    }

        .ev-card:hover {
            transform: translateY(-4px);
            border-color: rgba(232,255,71,0.2);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4), 0 0 0 1px rgba(232,255,71,0.1);
            color: inherit;
            text-decoration: none;
        }

        .ev-card:nth-child(1) {
            animation-delay: 0.05s;
        }

        .ev-card:nth-child(2) {
            animation-delay: 0.1s;
        }

        .ev-card:nth-child(3) {
            animation-delay: 0.15s;
        }

        .ev-card:nth-child(4) {
            animation-delay: 0.2s;
        }

        .ev-card:nth-child(5) {
            animation-delay: 0.25s;
        }

        .ev-card:nth-child(6) {
            animation-delay: 0.3s;
        }

    /* card image */
    .ev-card-img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        display: block;
    }

    .ev-card-img-placeholder {
        width: 100%;
        height: 180px;
        background: var(--surface2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        position: relative;
        overflow: hidden;
    }

        .ev-card-img-placeholder::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(232,255,71,0.05) 0%, transparent 50%, rgba(255,107,53,0.05) 100%);
        }

    /* card body */
    .ev-card-body {
        padding: 1.25rem;
    }

    .ev-card-cats {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-bottom: 10px;
    }

    .ev-cat-tag {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        padding: 3px 9px;
        border-radius: 20px;
    }

    .ev-card-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 8px;
        letter-spacing: -0.01em;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .ev-card-meta {
        display: flex;
        flex-direction: column;
        gap: 5px;
        margin-bottom: 14px;
    }

    .ev-card-meta-row {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 0.8rem;
        color: var(--muted);
    }

    .ev-meta-icon {
        width: 14px;
        height: 14px;
        flex-shrink: 0;
        opacity: 0.6;
    }

    .ev-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 12px;
        border-top: 1px solid var(--border);
    }

    .ev-price {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--accent);
    }

    .ev-price-free {
        color: #2ECC71;
    }

    .ev-capacity {
        font-size: 0.75rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .ev-btn-card {
        font-size: 0.8rem;
        padding: 6px 14px;
        border-radius: 8px;
        background: rgba(232,255,71,0.1);
        color: var(--accent);
        border: 1px solid rgba(232,255,71,0.2);
        font-weight: 600;
        transition: all 0.2s;
    }

    .ev-card:hover .ev-btn-card {
        background: var(--accent);
        color: #000;
        border-color: var(--accent);
    }

    /* ── EMPTY STATE ── */
    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 5rem 2rem;
        color: var(--muted);
    }

    .empty-state-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        opacity: 0.4;
    }

    .empty-state-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.5rem;
    }

    /* ── ANIMATIONS ── */
    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ── DIVIDER ── */
    .section-divider {
        border: none;
        border-top: 1px solid var(--border);
        margin: 3.5rem 0;
    }
</style>

<!-- HERO -->
<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-label">
        <span class="hero-label-dot"></span>
        Live Event Platform
    </div>
    <h1 class="hero-title">
        Discover &amp;<br>
        <span>Experience</span><br>
        Events
    </h1>
    <p class="hero-sub">
        Find concerts, conferences, workshops and more.
        Book your spot in seconds.
    </p>
    <div class="hero-actions">
        @if (!User.Identity!.IsAuthenticated)
        {
            <a asp-controller="Auth" asp-action="Register" class="ev-btn ev-btn-accent" style="font-size:0.95rem; padding:10px 24px;">
                Get Started
            </a>
            <a asp-controller="Auth" asp-action="Login" class="ev-btn ev-btn-ghost" style="font-size:0.95rem; padding:10px 24px;">
                Sign In
            </a>
        }
        else
        {
            <a asp-controller="Events" asp-action="Index" class="ev-btn ev-btn-accent" style="font-size:0.95rem; padding:10px 24px;">
                Browse All Events
            </a>
        }
    </div>
    <div class="hero-stat">
        <div class="stat-item">
            <div class="stat-num">@Model.Count()</div>
            <div class="stat-label">Upcoming Events</div>
        </div>
        <div class="stat-item">
            <div class="stat-num">@Model.Count(e => e.TicketPrice == 0)</div>
            <div class="stat-label">Free Events</div>
        </div>
        <div class="stat-item">
            <div class="stat-num">@Model.Select(e => e.VenuesId).Distinct().Count()</div>
            <div class="stat-label">Venues</div>
        </div>
    </div>
</section>

<hr class="section-divider" />

<!-- EVENTS GRID -->
<section>
    <div class="section-header">
        <div>
            <h2 class="section-title">Upcoming Events</h2>
            <p class="section-sub">Handpicked experiences happening near you</p>
        </div>
        <a asp-controller="Events" asp-action="Index" class="ev-btn ev-btn-ghost" style="font-size:0.8rem;">
            View all →
        </a>
    </div>

    <div class="events-grid">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">🎭</div>
                <div class="empty-state-title">No upcoming events yet</div>
                <p>Check back soon or create the first event.</p>
                @if (User.IsInRole("Admin") || User.IsInRole("Organizer"))
                {
                    <a asp-controller="Events" asp-action="Create" class="ev-btn ev-btn-accent mt-3">
                        + Create Event
                    </a>
                }
            </div>
        }
        else
        {
            @foreach (var evt in Model)
            {
                <a class="ev-card" asp-controller="Events" asp-action="Details" asp-route-id="@evt.Id">

                    @* Image *@
                    @if (!string.IsNullOrEmpty(evt.ImageUrl))
                    {
                        <img class="ev-card-img" src="@evt.ImageUrl" alt="@evt.Title" />
                    }
                    else
                    {
                        <div class="ev-card-img-placeholder">🎪</div>
                    }

                    <div class="ev-card-body">

                        @* Categories *@
                        @if (evt.EventCategories?.Any() == true)
                        {
                            <div class="ev-card-cats">
                                @foreach (var ec in evt.EventCategories.Take(2))
                                {
                                    <span class="ev-cat-tag"
                                          style="background:@(ec.Categories?.ColorHex ?? "#333")22;
                                                                 color:@(ec.Categories?.ColorHex ?? "#aaa")">
                                        @ec.Categories?.Name
                                    </span>
                                }
                            </div>
                        }

                        @* Title *@
                        <div class="ev-card-title">@evt.Title</div>

                        @* Meta *@
                        <div class="ev-card-meta">
                            <div class="ev-card-meta-row">
                                <svg class="ev-meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" />
                                    <line x1="16" y1="2" x2="16" y2="6" />
                                    <line x1="8" y1="2" x2="8" y2="6" />
                                    <line x1="3" y1="10" x2="21" y2="10" />
                                </svg>
                                @evt.StartDate.ToString("dd MMM yyyy · HH:mm")
                            </div>
                            @if (evt.Venues != null)
                            {
                                <div class="ev-card-meta-row">
                                    <svg class="ev-meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" />
                                        <circle cx="12" cy="9" r="2.5" />
                                    </svg>
                                    @evt.Venues.Name, @evt.Venues.City
                                </div>
                            }
                        </div>

                        @* Footer *@
                        <div class="ev-card-footer">
                            <div>
                                @if (evt.TicketPrice == 0)
                                {
                                    <div class="ev-price ev-price-free">Free</div>
                                }
                                else
                                {
                                    <div class="ev-price">$@evt.TicketPrice.ToString("F2")</div>
                                }
                                <div class="ev-capacity">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                        <circle cx="9" cy="7" r="4" />
                                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                                    </svg>
                                    @evt.MaxCapacity spots
                                </div>
                            </div>
                            <span class="ev-btn-card">View →</span>
                        </div>

                    </div>
                </a>
            }
        }
    </div>
</section>
